"https://www.cmi-pb.org/api/specimen",
simplifyVector = TRUE)
titer <- read_json(
"https://www.cmi-pb.org/api/ab_titer",
simplifyVector = TRUE)
titer <- read_json(
"https://www.cmi-pb.org/api/ab_titer/",
simplifyVector = TRUE)
library(httr)
library(jsonlite)
specimen <- read_json(
"https://www.cmi-pb.org/api/specimen",
simplifyVector = TRUE)
titer <- read_json(
"https://www.cmi-pb.org/api/ab_titer/",
simplifyVector = TRUE)
library(httr)
library(jsonlite)
res <- GET("https://www.cmi-pb.org/api/ab_titer/")
titer <- fromJSON(content(res, "text"), simplifyVector = TRUE)
specimen <- read_json(
"https://www.cmi-pb.org/api/specimen",
simplifyVector = TRUE)
titer <- read_json(
"https://www.cmi-pb.org/api/ab_titer/",
simplifyVector = TRUE)
head(titer)
titer <- read_json(
"https://www.cmi-pb.org/api/v1/ab_titer",
simplifyVector = TRUE
)
head(titer)
meta <- inner_join(specimen, subject)
dim(meta)
head(meta)
meta <- inner_join(specimen, subject, by = "subject_id")
dim(meta)
head(meta)
abdata <- inner_join(titer, meta)
abdata <- inner_join(titer, meta, by = "specimen_id")
names(titer)
str(titer)
library(httr)
library(jsonlite)
res <- GET("https://www.cmi-pb.org/api/v1/ab_titer")
titer <- fromJSON(content(res, "text"), simplifyVector = TRUE)
head(titer)
abdata <- inner_join(titer, meta, by = "specimen_id")
library(httr)
library(jsonlite)
res <- GET("https://www.cmi-pb.org/api/v1/ab_titer")
titer <- fromJSON(content(res, "text", encoding = "UTF-8"), flatten = TRUE)
names(titer)
head(titer)
abdata <- inner_join(titer, meta, by = "specimen_id")
names(titer)
str(titer)
abdata <- inner_join(meta, titer, by = c("specimen_id" = "sample_id"))
dim(abdata)
table(abdata$isotype)
table(abdata$dataset)
igg <- abdata %>% filter(isotype == "IgG")
head(igg)
ggplot(igg) +
aes(MFI_normalised, antigen) +
geom_boxplot() +
xlim(0,75) +
facet_wrap(vars(visit), nrow=2)
ggplot(igg) +
aes(ab_titer, antigen) +
geom_boxplot() +
xlim(0,75) +
facet_wrap(vars(visit), nrow=2)
filter(igg, antigen=="OVA") %>%
ggplot() +
aes(MFI_normalised, col=infancy_vac) +
geom_boxplot(show.legend = FALSE) +
facet_wrap(vars(visit)) +
theme_bw()
