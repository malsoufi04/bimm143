# File Location Online
url <- "https://raw.githubusercontent.com/jennybc/gapminder/master/inst/extdata/gapminder.tsv"
gapminder <- read.delim(url)
head(gapminder)
nrow(gapminder)
table(gapminder$continent)
ggplot(gapminder)+
aes(x=gdpPercap, y=lifeExp)+
geom_point()+
scale_color_manual(values = c("purple", "orange"))+
labs(x="GDP per Capita",
y="Life Expectancy",
title="The Average Life Expectancy based on GDP per Capita") +
theme_classic()
ggplot(gapminder)+
aes(x=gdpPercap, y=lifeExp)+
geom_point()+
scale_color_manual(values = c("blue", "red"))+
labs(x="GDP per Capita",
y="Life Expectancy",
title="The Average Life Expectancy based on GDP per Capita") +
theme_classic()
ggplot(gapminder)+
aes(x=gdpPercap, y=lifeExp)+
geom_point()+
scale_color_manual(values = c(x="blue", y="red"))+
labs(x="GDP per Capita",
y="Life Expectancy",
title="The Average Life Expectancy based on GDP per Capita") +
theme_classic()
ggplot(gapminder)+
aes(x=gdpPercap, y=lifeExp)+
geom_point()+
labs(x="GDP per Capita",
y="Life Expectancy",
title="The Average Life Expectancy based on GDP per Capita") +
theme_classic()
ggplot(gapminder)+
aes(x=gdpPercap, y=lifeExp, color=continent, size=pop)+
geom_point()+
labs(x="GDP per Capita",
y="Life Expectancy",
title="The Average Life Expectancy based on GDP per Capita") +
theme_classic()
ggplot(gapminder)+
aes(x=gdpPercap, y=lifeExp, color=continent, size=pop)+
geom_point(alpha=0.5)
labs(x="GDP per Capita",
y="Life Expectancy",
title="The Average Life Expectancy based on GDP per Capita") +
theme_classic()
ggplot(gapminder)+
aes(x=gdpPercap, y=lifeExp, color=continent, size=pop)+
geom_point(alpha=0.5)
labs(x="GDP per Capita",
y="Life Expectancy",
title="The Average Life Expectancy based on GDP per Capita") +
facet_wrap(~year)+
theme_classic()
ggplot(gapminder)+
aes(x=gdpPercap, y=lifeExp, color=continent, size=pop)+
geom_point(alpha=0.5)
labs(x="GDP per Capita",
y="Life Expectancy",
title="The Average Life Expectancy based on GDP per Capita") +
facet_wrap(~continent)
theme_classic()
ggplot(gapminder)+
aes(x=gdpPercap, y=lifeExp, color=continent, size=pop)+
geom_point(alpha=0.5)+
facet_wrap(~continent)
theme_classic()
