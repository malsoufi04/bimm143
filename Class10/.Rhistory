library(tidyverse)
install.packages("tidyverse")
library(tidyverse)
pdb <- read.csv("pdb_stats.csv")
head(pdb)
total_structures <- sum(pdb$Structure.count)
q1_results <- pdb %>%
filter(Experimental.method %in% c("X-ray Diffraction", "Electron Microscopy")) %>%
group_by(Experimental.method) %>%
summarise(count = sum(Structure.count)) %>%
mutate(percentage = (count / total_structures) * 100)
colnames(pdb)
total_structures <- sum(pdb$Total)
xray_count <- sum(pdb$X.ray)
em_count <- sum(pdb$EM)
xray_percent <- (xray_count / total_structures) * 100
em_percent <- (em_count / total_structures) * 100
xray_percent
em_percent
total_structures <- sum(pdb$Total)
protein_structures <- pdb$Total[pdb$Molecular.Type == "Protein"]
protein_proportion <- protein_structures / total_structures
protein_proportion
total_structures <- sum(pdb$Total)
protein_structures <- sum(
pdb$Total[grepl("Protein", pdb$Molecular.Type)]
)
protein_proportion <- protein_structures / total_structures
protein_proportion
